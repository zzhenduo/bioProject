{
  "name": "bio-ai-teaching-system",
  "version": "1.0.0",
  "description": "深究·生命 - 高中生物 AI 教学辅助系统",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "nodemon server/index.cjs",
    "start": "concurrently \"npm run server\" \"npm run dev\"",
    "electron:dev": "cross-env NODE_ENV=development electron .",
    "electron:build": "npm run build && electron-builder",
    "electron:preview": "npm run build && cross-env NODE_ENV=production electron ."
  },
  "keywords": [
    "biology",
    "ai",
    "education",
    "teaching"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@ant-design/icons": "^5.0.0",
    "antd": "^5.0.0",
    "axios": "^1.6.0",
    "better-sqlite3": "^11.0.0",
    "body-parser": "^1.20.0",
    "chart.js": "^4.4.0",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "docx": "^9.6.1",
    "express": "^4.18.0",
    "file-saver": "^2.0.5",
    "multer": "^1.4.5-lts.1",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@ant-design/cssinjs": "^1.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "cross-env": "^7.0.3",
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3",
    "nodemon": "^3.0.0",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.bioai.teaching",
    "productName": "深究·生命 - 生物 AI 教学系统",
    "directories": {
      "output": "release-final-1"
    },
    "asar": false,
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "server",
        "to": "server"
      },
      {
        "from": "node_modules",
        "to": "node_modules"
      }
    ],
    "npmRebuild": false,
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/",
      "cache": "./electron-cache"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/favicon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "深究·生命"
    }
  }
}
